# ScuPlan Environment Variables
# Copy this file to .env and fill in real values before deploying.

# Flask
SESSION_SECRET=change-me-to-a-random-secret-key

# Database (SQLite for dev; PostgreSQL for production)
DATABASE_URL=sqlite:///diveplan.db
# DATABASE_URL=postgresql://scuplan_user:change_me@localhost:5432/scuplan_db

# Google Analytics / Tag Manager
GOOGLE_TAG_ID=G-FZYPK08YL7

# Google Consent Mode v2 (true = show consent banner)
GOOGLE_CONSENT_MODE_ENABLED=true

# Google AdSense
# 1. Approve your site at https://www.google.com/adsense
# 2. Replace ca-pub-XXXXXXXXXXXXXXXXX with your Publisher ID
# 3. Replace slot IDs in whitelabel_settings.json
ADSENSE_ENABLED=true
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
# Auto Ads (page-level ads placed automatically by Google). Also enable
# "Auto ads" for scuplan.com in the AdSense dashboard.
ADSENSE_AUTO_ADS_ENABLED=true

# ── Affiliate IDs ─────────────────────────────────────────────
# Amazon Associates tracking tag (Affiliate Dashboard > Tracking IDs)
AMAZON_AFFILIATE_TAG=scuplan-20
# Liveaboard.com affiliate ID (apply at liveaboard.com/affiliates) — high
# ticket: $100-300+/booking. Links work untagged until this is filled in.
LIVEABOARD_AFFILIATE_ID=
# PADI eLearning affiliate deep link (Impact/CJ tracking URL)
PADI_AFFILIATE_URL=https://www.padi.com/courses/open-water-diver

# ── SEO ───────────────────────────────────────────────────────
# IndexNow key for free instant indexing (Bing/Yandex). Generate any
# 32+ char hex string, e.g.: python -c "import secrets; print(secrets.token_hex(16))"
# Served at /indexnow.txt; the blog agent pings api.indexnow.org after publishing.
INDEXNOW_KEY=

# ── AI Content Automation ─────────────────────────────────────
# Groq API key for the Blog Writer Agent (scripts/blog_writer_agent.py)
# Free tier at https://console.groq.com — model: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile
# Local Ollama for social captions (scripts/social_caption_generator.py)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# HuggingFace API Token — used for AI dive assistant and weekly blog generation
# Get from: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
